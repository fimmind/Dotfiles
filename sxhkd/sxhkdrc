#
# wm independent hotkeys
#

super + Return
	kitty

super + x
	kitty --class=float

super + g
	set pass_name (cd $PASSWORD_STORE_DIR && rg --files | sed 's/\.gpg$//' | rofi -dmenu -p "pass"); \
	test -n "$pass_name" && rofi -e (pass $pass_name -c)

super + d
	rofi -show drun

super + shift + d
	rofi -show window

super + {_, shift +} v
	seledit --editor "kitty --class=float -- nvim" --action {edit,write}

super + {_, shift +} e
	seledit --action {write,edit} --ext tex --editor "kitty -- nvim"

super + shift + b
	chromium

super + m
	xdo activate -n Telegram; Telegram

super + {n, b}
	set prog {ticktick,qutebrowser}; \
	if pgrep $prog; xdo activate -n $prog; else $prog; end

super + shift + m
	if pgrep cmus; \
		xdo activate -n cmus; \
	else \
		kitty --class=cmus -- cmus; \
	end

super + shift + n
	xdo activate -n AmneziaVPN; AmneziaVPN

# Window id is found by the title name containing "Anki" so as to only
# auto-focus the main Anki window
super + a
	if set id (xdotool search --all --class --name Anki); \
		xdo activate $id; \
	else; \
		bspc desktop -f ^6; \
		anki "" --no-sandbox; \
	end

super + z
	zathura

super + shift + z
	kitty --class=float -- fish -c xdg_fzf

super + c
	kitty --class=float ijconsole.sh

super + shift + c
	kitty --class=float -- qalc

super + shift + p
	powermenu

super + shift + Delete
	powermenu logout

super + {y,u,i,shift+i,o}
	set_layout {ipa,ru,en,latex,ja}

{_, shift +, ctrl +} Print
	screenshot {full,window,selection}

{XF86AudioLowerVolume,XF86AudioRaiseVolume,XF86AudioMute}
  amixer sset Master {5%-,5%+,toggle-mute}

{XF86AudioPlay,XF86AudioPause,XF86AudioPrev,XF86AudioNext}
  playerctl {play-pause,pause,previous,next} -p cmus

#
# bspwm hotkeys
#

# reload configuration files:
super + Delete
	bspc wm -r

# close and kill
super + shift + {q,x}
	bspc node -{c,k}

# rotate split
super + r
	bspc node -R 90

# swap the current node and the biggest window
super + shift + Return
	bspc node -s biggest.window.local

# set the window state
super + {t,s,shift + s,f}
	bspc node -t {tiled,pseudo_tiled,floating,\~fullscreen}

# Change focused node and move node
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}.local

# focus the node for the given path jump
super + {p,n}
	bspc node -f @{parent,first}

super + {comma,period}
	bspc node -f {prev,next}.local.!hidden.window

super + q
	bspc node 'focused.floating#next.local.!hidden.floating' -f \
	    || bspc node 'last.local.!focused.!hidden.floating' -f \
	    || bspc node  'any.local.!focused.!hidden.floating' -f

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'


# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + Delete
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + Delete
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

# more focused window to presel
super + ctrl + Return
	bspc node -n 'last.!automatic.local'

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -40 0,bottom 0 40,top 0 -40,right 40 0}

# contract a window by moving one of its side inward
super + alt + ctrl + {h,j,k,l}
	bspc node -z {right -40 0,top 0 40,bottom 0 -40,left 40 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-40 0,0 40,0 -40,40 0}
